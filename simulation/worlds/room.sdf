<?xml version="1.0" ?>
<!--
  Particle Filter Localization - simulation world (Gazebo Harmonic / gz-sim 8).

  Closed 6 x 4 m rectangular room with 8 AR-tag markers (2 per wall, placed
  ASYMMETRICALLY so the layout is locally unique) and a differential-drive robot
  with a forward-facing camera.

  Tag (x, y) centers here MUST stay in sync with pf_core/tag_map.py.

  Run (tags are model://aruco_marker, so the resource path must point at
  simulation/models):
    GZ_SIM_RESOURCE_PATH=$PWD/simulation/models gz sim simulation/worlds/room.sdf
  Drive: publish to /cmd_vel, or add the Teleop GUI widget.

  Tags: 8 x model://aruco_marker, all id=0 (DICT_4X4_50), placed asymmetrically.
  MIRROR CHECK (do this on a machine with GPU/camera): if the marker fails to
  decode because the visible face is mirrored, horizontally flip the texture in
  simulation/models/aruco_marker/generate_marker.py (cv2.flip(canvas, 1)).
-->
<sdf version="1.10">
  <world name="pf_room">

    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- ===== Keyboard teleop: arrow keys -> /cmd_vel =====================
         Requires the "Key Publisher" GUI widget (top-right vertical-dots menu
         -> Key Publisher). Then click the 3D view and use the arrow keys.
         Each press sends one Twist; the robot holds it until you change it.
         (Down = reverse, Space = stop.) -->
    <plugin filename="gz-sim-triggered-publisher-system" name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Int32" topic="/keyboard/keypress"><match field="data">16777235</match></input> <!-- Up -->
      <output type="gz.msgs.Twist" topic="/cmd_vel">linear: {x: 0.5}, angular: {z: 0.0}</output>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system" name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Int32" topic="/keyboard/keypress"><match field="data">16777237</match></input> <!-- Down -->
      <output type="gz.msgs.Twist" topic="/cmd_vel">linear: {x: -0.5}, angular: {z: 0.0}</output>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system" name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Int32" topic="/keyboard/keypress"><match field="data">16777234</match></input> <!-- Left -->
      <output type="gz.msgs.Twist" topic="/cmd_vel">linear: {x: 0.0}, angular: {z: 0.6}</output>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system" name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Int32" topic="/keyboard/keypress"><match field="data">16777236</match></input> <!-- Right -->
      <output type="gz.msgs.Twist" topic="/cmd_vel">linear: {x: 0.0}, angular: {z: -0.6}</output>
    </plugin>
    <plugin filename="gz-sim-triggered-publisher-system" name="gz::sim::systems::TriggeredPublisher">
      <input type="gz.msgs.Int32" topic="/keyboard/keypress"><match field="data">32</match></input> <!-- Space = stop -->
      <output type="gz.msgs.Twist" topic="/cmd_vel">linear: {x: 0.0}, angular: {z: 0.0}</output>
    </plugin>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.3 0.2 -0.9</direction>
    </light>

    <!-- ground -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>20 20</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>20 20</size></plane></geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ============ ROOM: 4 walls, interior 6 x 4 m, height 1 m ============ -->
    <model name="room">
      <static>true</static>
      <link name="walls">
        <!-- left wall  (x = -3), right wall (x = +3) -->
        <collision name="c_left"><pose>-3 0 0.5 0 0 0</pose>
          <geometry><box><size>0.1 4 1</size></box></geometry></collision>
        <visual name="v_left"><pose>-3 0 0.5 0 0 0</pose>
          <geometry><box><size>0.1 4 1</size></box></geometry>
          <material><ambient>0.7 0.7 0.75 1</ambient><diffuse>0.7 0.7 0.75 1</diffuse></material></visual>

        <collision name="c_right"><pose>3 0 0.5 0 0 0</pose>
          <geometry><box><size>0.1 4 1</size></box></geometry></collision>
        <visual name="v_right"><pose>3 0 0.5 0 0 0</pose>
          <geometry><box><size>0.1 4 1</size></box></geometry>
          <material><ambient>0.7 0.7 0.75 1</ambient><diffuse>0.7 0.7 0.75 1</diffuse></material></visual>

        <!-- front wall (y = -2), back wall (y = +2) -->
        <collision name="c_front"><pose>0 -2 0.5 0 0 0</pose>
          <geometry><box><size>6 0.1 1</size></box></geometry></collision>
        <visual name="v_front"><pose>0 -2 0.5 0 0 0</pose>
          <geometry><box><size>6 0.1 1</size></box></geometry>
          <material><ambient>0.7 0.7 0.75 1</ambient><diffuse>0.7 0.7 0.75 1</diffuse></material></visual>

        <collision name="c_back"><pose>0 2 0.5 0 0 0</pose>
          <geometry><box><size>6 0.1 1</size></box></geometry></collision>
        <visual name="v_back"><pose>0 2 0.5 0 0 0</pose>
          <geometry><box><size>6 0.1 1</size></box></geometry>
          <material><ambient>0.7 0.7 0.75 1</ambient><diffuse>0.7 0.7 0.75 1</diffuse></material></visual>
      </link>
    </model>

    <!-- ============ 8 ARUCO TAGS (asymmetric, 2 per wall, all id=0) ========
         Each is an instance of model://aruco_marker (textured face points +X),
         rotated so that face looks into the room. Centers MUST match
         pf_core/tag_map.py. Requires GZ_SIM_RESOURCE_PATH to include
         simulation/models (see run command in the world header comment).  -->
    <!-- LEFT wall x=-3 (face +x): yaw 0 -->
    <include><name>tag1</name><uri>model://aruco_marker</uri><pose>-2.94 -1.2 0.5 0 0 0</pose></include>
    <include><name>tag2</name><uri>model://aruco_marker</uri><pose>-2.94 0.8 0.5 0 0 0</pose></include>
    <!-- RIGHT wall x=+3 (face -x): yaw pi -->
    <include><name>tag3</name><uri>model://aruco_marker</uri><pose>2.94 -0.5 0.5 0 0 3.14159</pose></include>
    <include><name>tag4</name><uri>model://aruco_marker</uri><pose>2.94 1.4 0.5 0 0 3.14159</pose></include>
    <!-- FRONT wall y=-2 (face +y): yaw pi/2 -->
    <include><name>tag5</name><uri>model://aruco_marker</uri><pose>-2.0 -1.94 0.5 0 0 1.5708</pose></include>
    <include><name>tag6</name><uri>model://aruco_marker</uri><pose>1.0 -1.94 0.5 0 0 1.5708</pose></include>
    <!-- BACK wall y=+2 (face -y): yaw -pi/2 -->
    <include><name>tag7</name><uri>model://aruco_marker</uri><pose>-1.0 1.94 0.5 0 0 -1.5708</pose></include>
    <include><name>tag8</name><uri>model://aruco_marker</uri><pose>1.8 1.94 0.5 0 0 -1.5708</pose></include>

    <!-- ===================== DIFF-DRIVE ROBOT + CAMERA ===================== -->
    <model name="robot">
      <pose>0 0 0.12 0 0 0</pose>

      <link name="base_link">
        <inertial>
          <mass>5.0</mass>
          <inertia><ixx>0.08</ixx><iyy>0.1</iyy><izz>0.1</izz>
                   <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
        <collision name="col"><geometry><box><size>0.4 0.3 0.15</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.4 0.3 0.15</size></box></geometry>
          <material><ambient>0.1 0.3 0.8 1</ambient><diffuse>0.1 0.3 0.8 1</diffuse></material></visual>

        <!-- forward-facing camera at the front of the chassis -->
        <sensor name="camera" type="camera">
          <pose>0.2 0 0.05 0 0 0</pose>
          <always_on>1</always_on>
          <update_rate>30</update_rate>
          <topic>camera</topic>
          <camera>
            <horizontal_fov>2.0</horizontal_fov>
            <image><width>640</width><height>480</height><format>R8G8B8</format></image>
            <clip><near>0.05</near><far>15</far></clip>
          </camera>
        </sensor>
      </link>

      <!-- left wheel -->
      <link name="left_wheel">
        <pose>0 0.2 0 -1.5708 0 0</pose>
        <inertial><mass>0.5</mass>
          <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz>
                   <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>
        <collision name="col"><geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry></collision>
        <visual name="vis"><geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
      </link>
      <!-- right wheel -->
      <link name="right_wheel">
        <pose>0 -0.2 0 -1.5708 0 0</pose>
        <inertial><mass>0.5</mass>
          <inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz>
                   <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>
        <collision name="col"><geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry></collision>
        <visual name="vis"><geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
      </link>
      <!-- rear caster (sphere) for balance -->
      <link name="caster">
        <pose>-0.15 0 -0.07 0 0 0</pose>
        <inertial><mass>0.1</mass>
          <inertia><ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz>
                   <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>
        <collision name="col"><geometry><sphere><radius>0.05</radius></sphere></geometry>
          <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><sphere><radius>0.05</radius></sphere></geometry></visual>
      </link>

      <joint name="left_wheel_joint" type="revolute">
        <parent>base_link</parent><child>left_wheel</child>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
      </joint>
      <joint name="right_wheel_joint" type="revolute">
        <parent>base_link</parent><child>right_wheel</child>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
      </joint>
      <joint name="caster_joint" type="ball">
        <parent>base_link</parent><child>caster</child>
      </joint>

      <!-- differential drive: subscribes /cmd_vel, publishes /odom -->
      <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>
        <wheel_separation>0.4</wheel_separation>
        <wheel_radius>0.1</wheel_radius>
        <odom_publish_frequency>30</odom_publish_frequency>
        <topic>cmd_vel</topic>
        <odom_topic>odom</odom_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
      </plugin>
    </model>

  </world>
</sdf>
