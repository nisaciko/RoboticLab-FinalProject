<?xml version="1.0"?>
<model>
  <name>robot</name>
  <version>1.0</version>
  <sdf version="1.10">model.sdf</sdf>
  <author><name>Nisa</name></author>
  <description>
    Differential-drive robot with a forward-facing camera. Publishes /odom and
    /camera (+ /camera_info), subscribes /cmd_vel. Spawn at z = wheel radius
    (0.1) so the wheels rest on the floor; the room world sets that via the
    include pose.
  </description>
</model>
